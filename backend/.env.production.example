# TUCC Cyber Security Club - Production Environment Template

# Server Port
PORT=5000

# Node Environment
NODE_ENV=production

# JWT Secret Key (MUST CHANGE THIS)
JWT_SECRET=production_super_secret_key_change_me_before_deploy

# Frontend URL (can be your domain, or same as backend if serving from same host)
FRONTEND_URL=https://your-domain.com

# Database Path
DB_PATH=./cyberclub.db
