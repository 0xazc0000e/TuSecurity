# TUCC Cyber Security Club - Environment Configuration

# ==========================================
# Backend Configuration
# ==========================================

# Server Port (default: 3001)
PORT=3001

# JWT Secret Key (generate a secure random string for production)
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production

# Node Environment (development/production)
NODE_ENV=development

# Frontend URL for CORS (change in production)
FRONTEND_URL=http://localhost:5173

# Database Path (optional, defaults to ./cyberclub.db)
DB_PATH=./cyberclub.db

# ==========================================
# Frontend Configuration
# ==========================================

# API Base URL (change to your production backend URL)
VITE_API_URL=http://localhost:3001/api

# ==========================================
# Security Notes
# ==========================================
# 1. Never commit .env files with real secrets to version control
# 2. Use strong, unique JWT secrets in production
# 3. Change default admin credentials after first login
# 4. Use HTTPS in production environments
# 5. Regularly rotate secrets and API keys
